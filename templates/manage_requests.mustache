<div class="secondary-navigation d-print-none mb-3">
    <nav class="moremenu navigation">
        <ul role="tablist" class="nav more-nav nav-tabs">
            {{#filters}}
            <li data-key="{{label}}" class="nav-item" role="none" data-forceintomoremenu="false">
                <a role="tab" class="nav-link {{#active}}active{{/active}}" href="{{url}}" data-text="{{label}}" {{#active}}aria-selected="true"{{/active}} {{^active}}tabindex="-1"{{/active}}>
                    {{label}}
                </a>
            </li>
            {{/filters}}
        </ul>
    </nav>
</div>

{{#has_requests}}
<div class="table-responsive">
    <table class="table table-striped">
        <thead>
            <tr>
                <th>{{#str}}user, local_solicitacoes{{/str}}</th>
                <th>{{#str}}action_type, local_solicitacoes{{/str}}</th>
                <th>{{#str}}course, local_solicitacoes{{/str}}</th>
                <th>{{#str}}target_users, local_solicitacoes{{/str}}</th>
                <th>{{#str}}role, local_solicitacoes{{/str}}</th>
                <th>{{#str}}created_at, local_solicitacoes{{/str}}</th>
                <th>{{#str}}status, local_solicitacoes{{/str}}</th>
                <th>{{#str}}actions, local_solicitacoes{{/str}}</th>
            </tr>
        </thead>
        <tbody>
            {{#requests}}
            <tr>
                <td>{{{solicitante_link}}}</td>
                <td>{{acao_label}}</td>
                <td>{{{cursos_display}}}</td>
                <td>{{{usuarios_display}}}</td>
                <td>{{papel_display}}</td>
                <td>{{created_date}}</td>
                <td>{{status_label}}</td>
                <td>
                    {{#show_approve}}
                    <a href="{{approve_url}}" class="btn btn-sm btn-secondary">{{#str}}approve, local_solicitacoes{{/str}}</a>
                    {{/show_approve}}
                    {{#show_reject}}
                    <a href="{{reject_url}}" class="btn btn-sm btn-secondary">{{#str}}deny, local_solicitacoes{{/str}}</a>
                    {{/show_reject}}
                    <a href="{{view_url}}" class="btn btn-sm btn-secondary">{{#str}}view, local_solicitacoes{{/str}}</a>
                    <a href="{{delete_url}}" class="btn btn-sm btn-secondary" onclick="return confirm('{{confirm_delete_msg}}');">{{#str}}delete, local_solicitacoes{{/str}}</a>
                </td>
            </tr>
            {{/requests}}
        </tbody>
    </table>
</div>
{{/has_requests}}

{{^has_requests}}
<p>{{#str}}no_requests, local_solicitacoes{{/str}}</p>
{{/has_requests}}
