<div class="local-solicitacoes-form-container">
    <form id="request_form" method="post" action="{{action_url}}" class="mform">
        <input type="hidden" name="sesskey" value="{{sesskey}}">
        <input type="hidden" name="submitbutton" value="1">
        <input type="hidden" name="form_submitted" value="1">
        <input type="hidden" name="curso_id_selected" id="curso_id_selected" value="">
        <input type="hidden" name="usuarios_ids_selected" id="usuarios_ids_selected" value="">
        <input type="hidden" name="usuarios_nomes" id="usuarios_nomes" value="">

        <div class="row mb-3">
            <div class="col-md-12">
                <div class="form-group">
                    <label for="tipo_acao" class="form-label">
                        {{#str}}tipo_acao, local_solicitacoes{{/str}}
                        <span class="text-danger">*</span>
                    </label>
                    <select name="tipo_acao" id="tipo_acao" class="form-select form-control" required>
                        {{#acoes}}
                            <option value="{{value}}">{{label}}</option>
                        {{/acoes}}
                    </select>
                </div>
            </div>
        </div>

        <div class="row mb-3" id="curso_container">
            <div class="col-md-12">
                <div class="form-group">
                    <label for="curso_search" class="form-label">
                        {{#str}}curso_nome, local_solicitacoes{{/str}}
                        <span class="text-danger">*</span>
                    </label>
                    <input type="text" 
                           name="curso_search" 
                           id="curso_search" 
                           placeholder="Digite para buscar cursos..."
                           autocomplete="off"
                           required>
                    <small class="form-text text-muted">
                        {{#str}}curso_nome_help, local_solicitacoes{{/str}}
                    </small>
                </div>
            </div>
        </div>

        <div class="row mb-3" id="usuarios_container">
            <div class="col-md-12">
                <div class="form-group">
                    <label for="usuarios_search" class="form-label">
                        {{#str}}usuarios_busca, local_solicitacoes{{/str}}
                        <span class="text-danger">*</span>
                    </label>
                    <input type="text" 
                           name="usuarios_search" 
                           id="usuarios_search" 
                           placeholder="Digite para buscar usuários..."
                           autocomplete="off"
                           required>
                    <small class="form-text text-muted">
                        {{#str}}usuarios_busca_help, local_solicitacoes{{/str}}
                    </small>
                </div>
            </div>
        </div>

        <div class="row mb-3" id="cadastro_container" style="display: none;">
            <div class="col-md-6">
                <div class="form-group">
                    <label for="firstname" class="form-label">
                        {{#str}}firstname, local_solicitacoes{{/str}}
                        <span class="text-danger">*</span>
                    </label>
                    <input type="text" 
                           name="firstname" 
                           id="firstname" 
                           class="form-control"
                           placeholder="Primeiro nome..."
                           autocomplete="off">
                    <small class="form-text text-muted">
                        {{#str}}firstname_help, local_solicitacoes{{/str}}
                    </small>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label for="lastname" class="form-label">
                        {{#str}}lastname, local_solicitacoes{{/str}}
                        <span class="text-danger">*</span>
                    </label>
                    <input type="text" 
                           name="lastname" 
                           id="lastname" 
                           class="form-control"
                           placeholder="Sobrenome..."
                           autocomplete="off">
                    <small class="form-text text-muted">
                        {{#str}}lastname_help, local_solicitacoes{{/str}}
                    </small>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label for="cpf" class="form-label">
                        {{#str}}cpf, local_solicitacoes{{/str}}
                        <span class="text-danger">*</span>
                    </label>
                    <input type="text" 
                           name="cpf" 
                           id="cpf" 
                           class="form-control"
                           placeholder="00000000000"
                           pattern="[0-9]{11}"
                           maxlength="11"
                           autocomplete="off">
                    <small class="form-text text-muted">
                        {{#str}}cpf_help, local_solicitacoes{{/str}}
                    </small>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label for="email_novo_usuario" class="form-label">
                        {{#str}}email_novo_usuario, local_solicitacoes{{/str}}
                        <span class="text-danger">*</span>
                    </label>
                    <input type="email" 
                           name="email_novo_usuario" 
                           id="email_novo_usuario" 
                           class="form-control"
                           placeholder="email@exemplo.com"
                           autocomplete="off">
                    <small class="form-text text-muted">
                        {{#str}}email_novo_usuario_help, local_solicitacoes{{/str}}
                    </small>
                </div>
            </div>
        </div>

        <div class="row mb-3" id="papel_container">
            <div class="col-md-12">
                <div class="form-group">
                    <label for="papel" class="form-label">
                        {{#str}}papel, local_solicitacoes{{/str}}
                        <span class="text-danger">*</span>
                    </label>
                    <select name="papel" id="papel" class="form-select form-control">
                        <option value="">Selecione...</option>
                        {{#papeis}}
                            <option value="{{value}}">{{label}}</option>
                        {{/papeis}}
                    </select>
                    <small class="form-text text-muted">
                        {{#str}}papel_help, local_solicitacoes{{/str}}
                    </small>
                </div>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-12">
                <div class="form-group">
                    <label for="observacoes" class="form-label">
                        {{#str}}observacoes, local_solicitacoes{{/str}}
                    </label>
                    <textarea name="observacoes" 
                              id="observacoes" 
                              class="form-control" 
                              rows="4" 
                              placeholder="Informações adicionais (opcional)"></textarea>
                    <small class="form-text text-muted">
                        {{#str}}observacoes_help, local_solicitacoes{{/str}}
                    </small>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-12">
                <div class="form-group d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        {{#str}}request_submit, local_solicitacoes{{/str}}
                    </button>
                    <a href="{{cancel_url}}" class="btn btn-secondary">
                        {{#str}}cancel{{/str}}
                    </a>
                </div>
            </div>
        </div>
    </form>
</div>
