{{!
    Template para formulário específico de inscrição de usuários
}}

<div class="local-solicitacoes-form-container">
    {{#is_teacher}}
    <div class="alert alert-info" role="alert">
        <i class="fas fa-info-circle"></i> Você está solicitando vinculação de <strong>{{papel_label}}</strong> a uma disciplina.
    </div>
    {{/is_teacher}}
    
    {{^is_teacher}}
    <div class="alert alert-info" role="alert">
        <i class="fas fa-info-circle"></i> Você está solicitando inscrição de <strong>{{papel_label}}</strong> em uma disciplina.
    </div>
    {{/is_teacher}}

    <form id="form_inscricao" method="post" action="{{action_url}}" class="mform">
        <input type="hidden" name="sesskey" value="{{sesskey}}">
        <input type="hidden" name="submitbutton" value="1">
        <input type="hidden" name="curso_id_selected" id="curso_id_selected" value="">
        <input type="hidden" name="usuarios_ids_selected" id="usuarios_ids_selected" value="">

        <div class="row mb-3">
            <div class="col-12">
                <div class="form-group">
                    <label for="curso_nome" class="form-label">
                        {{#str}}curso_nome, local_solicitacoes{{/str}}
                        <span class="text-danger">*</span>
                    </label>
                    <select name="curso_nome" 
                            id="curso_nome" 
                            class="form-control" 
                            required>
                        <option value="">{{#str}}searching_courses, local_solicitacoes{{/str}}</option>
                    </select>
                    <small class="form-text text-muted">
                        {{#str}}curso_nome_help, local_solicitacoes{{/str}}
                    </small>
                </div>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-12">
                <div class="form-group">
                    <label for="usuarios_busca" class="form-label">
                        {{#str}}usuarios_busca, local_solicitacoes{{/str}}
                        <span class="text-danger">*</span>
                    </label>
                    <select name="usuarios_busca" 
                            id="usuarios_busca" 
                            class="form-control" 
                            multiple 
                            required>
                    </select>
                    <small class="form-text text-muted">
                        {{#str}}usuarios_busca_help, local_solicitacoes{{/str}}
                    </small>
                </div>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-12">
                <div class="form-group">
                    <label for="observacoes" class="form-label">
                        {{#str}}observacoes, local_solicitacoes{{/str}}
                    </label>
                    <textarea name="observacoes" 
                              id="observacoes" 
                              class="form-control" 
                              rows="4" 
                              placeholder="{{#str}}observacoes_help, local_solicitacoes{{/str}}"></textarea>
                </div>
            </div>
        </div>

        <div class="form-group mt-4">
            <button type="submit" name="submitbutton" class="btn btn-primary">
                <i class="fas fa-paper-plane"></i> {{#str}}request_submit, local_solicitacoes{{/str}}
            </button>
            <a href="{{cancel_url}}" class="btn btn-secondary">
                <i class="fas fa-times"></i> {{#str}}cancel{{/str}}
            </a>
        </div>
    </form>
</div>

{{#js}}
require(['jquery'], function($) {
    $(document).ready(function() {
        if (typeof TomSelect !== 'undefined') {
            // Tom Select para cursos
            var cursoSelect = new TomSelect('#curso_nome', {
                valueField: 'id',
                labelField: 'fullname',
                searchField: 'fullname',
                placeholder: '{{#str}}curso_nome_help, local_solicitacoes{{/str}}',
                load: function(query, callback) {
                    if (!query.length) return callback();
                    
                    $.ajax({
                        url: M.cfg.wwwroot + '/local/solicitacoes/ajax/buscar-cursos.php',
                        type: 'GET',
                        dataType: 'json',
                        data: { q: query },
                        success: function(data) {
                            callback(data);
                        },
                        error: function() {
                            callback();
                        }
                    });
                },
                onChange: function(value) {
                    $('#curso_id_selected').val(value);
                }
            });
            
            // Tom Select para usuários
            var usuariosSelect = new TomSelect('#usuarios_busca', {
                valueField: 'id',
                labelField: 'fullname',
                searchField: ['fullname', 'email'],
                placeholder: '{{#str}}usuarios_busca_help, local_solicitacoes{{/str}}',
                render: {
                    option: function(data, escape) {
                        return '<div><strong>' + escape(data.fullname) + '</strong><br><small>' + escape(data.email) + '</small></div>';
                    }
                },
                load: function(query, callback) {
                    if (!query.length) return callback();
                    
                    $.ajax({
                        url: M.cfg.wwwroot + '/local/solicitacoes/ajax/buscar-usuarios.php',
                        type: 'GET',
                        dataType: 'json',
                        data: { q: query },
                        success: function(data) {
                            callback(data);
                        },
                        error: function() {
                            callback();
                        }
                    });
                },
                onChange: function(value) {
                    $('#usuarios_ids_selected').val(value.join(','));
                }
            });
        }
    });
});
{{/js}}
