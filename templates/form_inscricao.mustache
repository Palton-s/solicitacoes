{{#js}}
require(['jquery'], function($) {
    $(document).ready(function() {
        if (typeof TomSelect !== 'undefined') {
            // Tom Select para cursos
            var cursoSelect = new TomSelect('#curso_nome', {
                valueField: 'id',
                labelField: 'fullname',
                searchField: 'fullname',
                placeholder: '{{#str}}curso_nome_help, local_solicitacoes{{/str}}',
                load: function(query, callback) {
                    if (!query.length) return callback();
                    
                    $.ajax({
                        url: M.cfg.wwwroot + '/local/solicitacoes/ajax/buscar-cursos.php',
                        type: 'GET',
                        dataType: 'json',
                        data: { q: query },
                        success: function(data) {
                            callback(data);
                        },
                        error: function() {
                            callback();
                        }
                    });
                },
                onChange: function(value) {
                    console.log('TomSelect Curso - onChange triggered, value:', value);
                    $('#curso_id_selected').val(value || '');
                    console.log('TomSelect Curso - Hidden field updated:', $('#curso_id_selected').val());
                }
            });
            
            // Tom Select para usuários
            var usuariosSelect = new TomSelect('#usuarios_busca', {
                valueField: 'id',
                labelField: 'fullname',
                searchField: ['fullname', 'email'],
                placeholder: '{{#str}}usuarios_busca_help, local_solicitacoes{{/str}}',
                render: {
                    option: function(data, escape) {
                        return '<div><strong>' + escape(data.fullname) + '</strong><br><small>' + escape(data.email) + '</small></div>';
                    }
                },
                load: function(query, callback) {
                    if (!query.length) return callback();
                    
                    $.ajax({
                        url: M.cfg.wwwroot + '/local/solicitacoes/ajax/buscar-usuarios.php',
                        type: 'GET',
                        dataType: 'json',
                        data: { q: query },
                        success: function(data) {
                            callback(data);
                        },
                        error: function() {
                            callback();
                        }
                    });
                },
                onChange: function(value) {
                    var selectedIds = Array.isArray(value) ? value.join(',') : '';
                    console.log('TomSelect Usuários - onChange triggered, value:', value);
                    console.log('TomSelect Usuários - selectedIds string:', selectedIds);
                    $('#usuarios_ids_selected').val(selectedIds);
                    console.log('TomSelect Usuários - Hidden field updated:', $('#usuarios_ids_selected').val());
                }
            });
            
            // Listener para o campo papel
            $('#papel').on('change', function() {
                console.log('Campo Papel - onChange triggered, value:', $(this).val());
            });
            
            // Validação antes de submeter
            $('#form_inscricao').on('submit', function(e) {
                console.log('=== FORM SUBMIT TRIGGERED ===');
                var cursoId = $('#curso_id_selected').val();
                var usuariosIds = $('#usuarios_ids_selected').val();
                var papel = $('#papel').val();
                var sesskey = $('input[name="sesskey"]').val();
                var submitbutton = $('input[name="submitbutton"]').val();
                
                console.log('Curso ID:', cursoId, 'Type:', typeof cursoId, 'Empty:', !cursoId);
                console.log('Usuarios IDs:', usuariosIds, 'Type:', typeof usuariosIds, 'Empty:', !usuariosIds);
                console.log('Papel:', papel, 'Type:', typeof papel, 'Empty:', !papel);
                console.log('Sesskey:', sesskey);
                console.log('Submitbutton:', submitbutton);
                
                // Mostrar todos os dados do formulário
                var formData = $(this).serializeArray();
                console.log('=== FORM DATA COMPLETO ===');
                console.table(formData);
                
                if (!cursoId || cursoId === '') {
                    e.preventDefault();
                    console.error('ERRO: Curso não selecionado');
                    alert('Por favor, selecione um curso.');
                    return false;
                }
                
                if (!usuariosIds || usuariosIds === '') {
                    e.preventDefault();
                    console.error('ERRO: Usuários não selecionados');
                    alert('Por favor, selecione pelo menos um usuário.');
                    return false;
                }
                
                if (!papel || papel === '') {
                    e.preventDefault();
                    console.error('ERRO: Papel não selecionado');
                    alert('Por favor, selecione um papel.');
                    return false;
                }
                
                console.log('=== VALIDACAO OK, SUBMETENDO PARA: ' + $(this).attr('action') + ' ===');
                return true;
            });
        }
    });
});
{{/js}}
