{{!
    Template para formulário específico de cadastro de novo usuário
}}

<div class="local-solicitacoes-form-container">
    <div class="alert alert-info" role="alert">
        <i class="fas fa-info-circle"></i> Preencha os dados do novo usuário que deseja cadastrar e vincular a uma disciplina.
    </div>

    <form id="form_cadastro" method="post" action="{{action_url}}" class="mform">
        <input type="hidden" name="sesskey" value="{{sesskey}}">
        <input type="hidden" name="submitbutton" value="1">
        <input type="hidden" name="curso_id_selected" id="curso_id_selected" value="">

        <div class="row mb-3">
            <div class="col-12">
                <div class="form-group">
                    <label for="curso_nome" class="form-label">
                        {{#str}}curso_nome, local_solicitacoes{{/str}}
                        <span class="text-danger">*</span>
                    </label>
                    <select name="curso_nome" 
                            id="curso_nome" 
                            class="form-control" 
                            required>
                        <option value="">{{#str}}searching_courses, local_solicitacoes{{/str}}</option>
                    </select>
                    <small class="form-text text-muted">
                        {{#str}}curso_nome_help, local_solicitacoes{{/str}}
                    </small>
                </div>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-12">
                <div class="form-group">
                    <label for="papel" class="form-label">
                        {{#str}}papel_label, local_solicitacoes{{/str}}
                        <span class="text-danger">*</span>
                    </label>
                    <select name="papel" id="papel" class="form-control" required>
                        <option value="">{{#str}}select_role, local_solicitacoes{{/str}}</option>
                        {{#roles}}
                        <option value="{{shortname}}">{{localname}}</option>
                        {{/roles}}
                    </select>
                    <small class="form-text text-muted">
                        {{#str}}papel_help_dinamico, local_solicitacoes{{/str}}
                    </small>
                </div>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <div class="form-group">
                    <label for="firstname" class="form-label">
                        {{#str}}firstname{{/str}}
                        <span class="text-danger">*</span>
                    </label>
                    <input type="text" 
                           name="firstname" 
                           id="firstname" 
                           class="form-control" 
                           required>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label for="lastname" class="form-label">
                        {{#str}}lastname{{/str}}
                        <span class="text-danger">*</span>
                    </label>
                    <input type="text" 
                           name="lastname" 
                           id="lastname" 
                           class="form-control" 
                           required>
                </div>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <div class="form-group">
                    <label for="cpf" class="form-label">
                        CPF
                        <span class="text-danger">*</span>
                    </label>
                    <input type="text" 
                           name="cpf" 
                           id="cpf" 
                           class="form-control" 
                           pattern="\d{3}\.\d{3}\.\d{3}-\d{2}" 
                           placeholder="000.000.000-00"
                           required>
                    <small class="form-text text-muted">Formato: 000.000.000-00</small>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label for="email_novo_usuario" class="form-label">
                        {{#str}}email{{/str}}
                        <span class="text-danger">*</span>
                    </label>
                    <input type="email" 
                           name="email_novo_usuario" 
                           id="email_novo_usuario" 
                           class="form-control" 
                           required>
                </div>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-12">
                <div class="form-group">
                    <label for="observacoes" class="form-label">
                        {{#str}}observacoes, local_solicitacoes{{/str}}
                    </label>
                    <textarea name="observacoes" 
                              id="observacoes" 
                              class="form-control" 
                              rows="4" 
                              placeholder="{{#str}}observacoes_help, local_solicitacoes{{/str}}"></textarea>
                </div>
            </div>
        </div>

        <div class="form-group mt-4">
            <button type="submit" name="submitbutton" class="btn btn-primary">
                <i class="fas fa-paper-plane"></i> {{#str}}request_submit, local_solicitacoes{{/str}}
            </button>
            <a href="{{cancel_url}}" class="btn btn-secondary">
                <i class="fas fa-times"></i> {{#str}}cancel{{/str}}
            </a>
        </div>
    </form>
</div>

{{#js}}
require(['jquery'], function($) {
    $(document).ready(function() {
        if (typeof TomSelect !== 'undefined') {
            // Tom Select para cursos
            var cursoSelect = new TomSelect('#curso_nome', {
                valueField: 'id',
                labelField: 'fullname',
                searchField: 'fullname',
                placeholder: '{{#str}}curso_nome_help, local_solicitacoes{{/str}}',
                load: function(query, callback) {
                    if (!query.length) return callback();
                    
                    $.ajax({
                        url: M.cfg.wwwroot + '/local/solicitacoes/ajax/buscar-cursos.php',
                        type: 'GET',
                        dataType: 'json',
                        data: { q: query },
                        success: function(data) {
                            callback(data);
                        },
                        error: function() {
                            callback();
                        }
                    });
                },
                onChange: function(value) {
                    console.log('TomSelect Curso - onChange triggered, value:', value);
                    $('#curso_id_selected').val(value || '');
                    console.log('TomSelect Curso - Hidden field updated:', $('#curso_id_selected').val());
                }
            });
            
            // Listener para o campo papel
            $('#papel').on('change', function() {
                console.log('Campo Papel - onChange triggered, value:', $(this).val());
            });
            
            // Validação antes de submeter
            $('#form_cadastro').on('submit', function(e) {
                console.log('=== FORM CADASTRO SUBMIT TRIGGERED ===');
                var cursoId = $('#curso_id_selected').val();
                var papel = $('#papel').val();
                var firstname = $('#firstname').val();
                var lastname = $('#lastname').val();
                var cpf = $('#cpf').val();
                var email = $('#email_novo_usuario').val();
                var sesskey = $('input[name="sesskey"]').val();
                var submitbutton = $('input[name="submitbutton"]').val();
                
                console.log('Curso ID:', cursoId, 'Empty:', !cursoId);
                console.log('Papel:', papel, 'Empty:', !papel);
                console.log('Firstname:', firstname, 'Empty:', !firstname);
                console.log('Lastname:', lastname, 'Empty:', !lastname);
                console.log('CPF:', cpf, 'Empty:', !cpf);
                console.log('Email:', email, 'Empty:', !email);
                console.log('Sesskey:', sesskey);
                console.log('Submitbutton:', submitbutton);
                
                var formData = $(this).serializeArray();
                console.log('=== FORM DATA COMPLETO ===');
                console.table(formData);
                
                if (!cursoId || cursoId === '') {
                    e.preventDefault();
                    console.error('ERRO: Curso não selecionado');
                    alert('Por favor, selecione um curso.');
                    return false;
                }
                
                if (!papel || papel === '') {
                    e.preventDefault();
                    console.error('ERRO: Papel não selecionado');
                    alert('Por favor, selecione um papel.');
                    return false;
                }
                
                if (!firstname || firstname.trim() === '') {
                    e.preventDefault();
                    console.error('ERRO: Nome não preenchido');
                    alert('Por favor, informe o primeiro nome.');
                    return false;
                }
                
                if (!lastname || lastname.trim() === '') {
                    e.preventDefault();
                    console.error('ERRO: Sobrenome não preenchido');
                    alert('Por favor, informe o sobrenome.');
                    return false;
                }
                
                if (!cpf || cpf.trim() === '') {
                    e.preventDefault();
                    console.error('ERRO: CPF não preenchido');
                    alert('Por favor, informe o CPF.');
                    return false;
                }
                
                if (!email || email.trim() === '') {
                    e.preventDefault();
                    console.error('ERRO: Email não preenchido');
                    alert('Por favor, informe o email.');
                    return false;
                }
                
                console.log('=== VALIDACAO OK, SUBMETENDO PARA: ' + $(this).attr('action') + ' ===');
                return true;
            });
        }
        
        // Máscara para CPF
        $('#cpf').on('input', function() {
            var value = $(this).val().replace(/\D/g, '');
            if (value.length <= 11) {
                value = value.replace(/(\d{3})(\d)/, '$1.$2');
                value = value.replace(/(\d{3})(\d)/, '$1.$2');
                value = value.replace(/(\d{3})(\d{1,2})$/, '$1-$2');
                $(this).val(value);
            }
        });
    });
});
{{/js}}
